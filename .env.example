# Flask settings
APP_ENV=development
SECRET_KEY=change-me
DATABASE_URL=sqlite:///dr_julio.db
ENABLE_DEBUG_ROUTES=false
HEALTHCHECK_TOKEN=
HEALTHCHECK_ALLOW_DETAILS=false
HEALTHCHECK_ALLOW_WRITE=false
ADMIN_API_KEY=
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@drjulio.com
ADMIN_PASSWORD=

# Email settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER="Dr. Julio Vasconcelos <noreply@drjulio.com>"
PUBLIC_BASE_URL=http://localhost:5000

# Availability settings
AVAIL_WORK_START=08:00
AVAIL_WORK_END=17:00
AVAIL_SLOT_MINUTES=30
AVAIL_CAPACITY=1

# Stripe settings
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# Hotmart settings
HOTMART_WEBHOOK_SECRET=
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=

# Google Calendar sync
# Optional fallback. The admin panel can store the service account JSON directly.
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TZ=America/Sao_Paulo
GOOGLE_APPT_DURATION_MINUTES=50
GOOGLE_SYNC_MIN_INTERVAL_MIN=2

# Chatbot limits
CHATBOT_MAX_MESSAGE_LENGTH=500
CHATBOT_MAX_HISTORY_ITEMS=30
CHATBOT_MAX_SESSION_ID_LENGTH=120
